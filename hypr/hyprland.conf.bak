exec-once = dbus-update-activation-environment --systemd DISPLAY HYPRLAND_INSTANCE_SIGNATURE WAYLAND_DISPLAY XDG_CURRENT_DESKTOP && systemctl --user stop hyprland-session.target && systemctl --user start hyprland-session.target
# load all the plugins you installed
exec-once = hyprctl plugin load "$HYPR_PLUGIN_DIR/lib/libhyprexpo.so"
$fileManager=nautilus
$home = $HOME
$mainMod = SUPER
$terminal = kitty
animations {
  bezier = overshoot,0.34,1.56,0.64,1
  bezier = easeOutQuint,0.23,1,0.32,1
  bezier = easeInOutCubic,0.65,0.05,0.36,1
  bezier = linear,0,0,1,1
  bezier = almostLinear,0.5,0.5,0.75,1.0
  bezier = quick,0.15,0,0.1,1
  animation = global, 1, 10, default
  animation = border, 1, 5.39, easeOutQuint
  animation = windows, 1, 4.79, easeOutQuint
  animation = windowsIn, 1, 4.1, easeOutQuint, popin 87%
  animation = windowsOut, 1, 1.49, linear, popin 87%
  animation = fadeIn, 1, 1.73, almostLinear
  animation = fadeOut, 1, 1.46, almostLinear
  animation =fade, 1, 3.03, quick
  animation =layers, 1, 3.81, easeOutQuint
  animation =layersIn, 1, 4, easeOutQuint, fade
  animation = layersOut, 1, 1.5, linear, fade
  animation = fadeLayersIn, 1, 1.79, almostLinear
  animation = fadeLayersOut, 1, 1.39, almostLinear
  animation = workspaces, 1, 5, overshoot
animation = workspacesIn, 1, 5, overshoot
animation = workspacesOut, 1, 4, easeOutQuint
  enabled = true
}

plugin {
    hyprbars {
        bar_height = 28

        hyprbars-button = rgb(ff5f57), 12, ’ĆŹ, hyprctl dispatch killactive

        hyprbars-button = rgb(ffbd2e), 12, ’ĆÉ, hyprctl dispatch movetoworkspace special:minimized

        hyprbars-button = rgb(28c840), 12, ’ŗÉ, hyprctl dispatch fullscreen 1

        on_double_click = hyprctl dispatch fullscreen 1
    }
}

cursor {
  inactive_timeout=3
  no_warps=false
}

decoration {
  blur {
    enabled=true
    passes=3
    size=6
    vibrancy=1
  }

  shadow {
    color=rgba(1a1a1a88)
    enabled=true
    range=4
    render_power=3
  }
  active_opacity=1.000000
  inactive_opacity=1.000000
  rounding=12
  rounding_power=2
}

device {
  name=epic-mouse-v1
  sensitivity=-0.500000
}

dwindle {
  preserve_split=true
  pseudotile=true
}

general {
  allow_tearing=false
  border_size=3
  col.active_border = rgba(1a1c20ff) rgba(9ca3afff) 45deg
  col.inactive_border = rgba(0b0d10ff)
  gaps_in=5
  gaps_out=5
  layout=dwindle
  resize_on_border=true
}

input {
  gesture = 3, horizontal, workspace
  repeat_delay = 200
  repeat_rate = 45
  touchpad {
    natural_scroll=true
  }
  follow_mouse=1
  kb_layout=br
  kb_model=
  kb_options=
  kb_rules=
  kb_variant=abnt2
  sensitivity=0
}

master {
  new_status=master
}

misc {
  disable_hyprland_logo=true
  force_default_wallpaper=-1
}

xwayland {
  force_zero_scaling=true
}


### STARTUPS

# Noctalia

exec-once = noctalia-shell &
# hypr extras
exec-once = hypridle
exec-once = hyprlock
exec-once = hyprpaper
#### END OF STARTUPS 


#### CUSTOM BINDS

# Screenshots/recording
bind=, Print, exec, grim -g "$(slurp)" - | wl-copy
bind=SHIFT, Print, exec, grim - | wl-copy
bind=$mainMod, Print, exec, mkdir -p ~/Pictures/Screenshots && grim -g "$(slurp)" ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png
bind=$mainMod SHIFT, Print, exec, mkdir -p ~/Pictures/Screenshots && grim ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png
bind=$mainMod, R, exec, $home/.local/share/custom/bin/toggle-screenrecord.sh

# Walker
bind=$mainMod, escape, exec, $home/.local/share/custom/bin/walker-menu.sh system
bind=$mainMod MOD5, escape, exec, $home/.local/share/custom/bin/walker-menu.sh power
bind=$mainMod, space, exec, $home/.local/share/custom/bin/walker-menu.sh apps

# Firefox
bind=$mainMod, B, exec, firefox

# Rofi
bind = $mainMod, D, exec, ~/.config/rofi/launchers/type-4/launcher.sh
bind = $mainMod, P, exec, ~/.config/rofi/powermenu/type-1/powermenu.sh

# Background cycling
# bind=$mainMod CTRL, space, exec, $home/.local/share/custom/bin/cycle-background.sh
# bind=$mainMod CTRL SHIFT, space, exec, $home/.local/share/custom/bin/cycle-moving-background.sh

#Terminal tools and widgets
# bind=$mainMod, ae, exec, $terminal --class=Logo -e bash -i -c '$home/.local/share/custom/bin/logo-printer.sh; exec bash'
# bind=MOD5, comma, togglespecialworkspace, Calculator
# bind=$mainMod, Return, exec, $terminal --working-directory=$home
# bind=$mainMod, L, exec, $terminal --class=FloatingTermL --working-directory=$home -e bash -ic 'lazygit'
# bind=$mainMod, U, exec, $terminal --class=FloatingTermS -e bash -ic 'unimatrix'
bind=$mainMod, N, exec,$terminal --working-directory=$home -e bash -ic 'nvim'

# Brilho

bind = , XF86MonBrightnessUp, exec, brightnessctl set +5%
bind = , XF86MonBrightnessDown, exec, brightnessctl set 5%-


# Volume
bind = , XF86AudioRaiseVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bind = , XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bind = , XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

# Window management
bind=$mainMod, M, fullscreen
bind=ALT, TAB, cyclenext
bind=$mainMod, H, togglespecialworkspace, magic
bind=$mainMod SHIFT, H, movetoworkspace, special:magic
bind=$mainMod, Y, togglespecialworkspace, spotify
bind=$mainMod, right, resizeactive, 200 0
bind=$mainMod, left, resizeactive, -200 0
bind=$mainMod SHIFT, H, movewindow, l
bind=$mainMod SHIFT, L, movewindow, r
bind=$mainMod SHIFT, J, movewindow, u
bind=$mainMod SHIFT, K, movewindow, d
bind=$mainMod, F, exec, $fileManager
bind=$mainMod, L, exec, hyprlock
binde=$mainMod, bar, exec, $terminal -e bash -ic 'unimatrix'
binde=$mainMod, TAB, exec, $terminal --working-directory=$home

# Audio stuff
bindel=,XF86AudioRaiseVolume, exec, $home/.local/share/custom/bin/volume-osd.sh up
bindel=,XF86AudioLowerVolume, exec, $home/.local/share/custom/bin/volume-osd.sh down
bindel=,XF86AudioMute, exec, $home/.local/share/custom/bin/volume-osd.sh mute
bindel=,XF86AudioMicMute, exec, $home/.local/share/custom/bin/mic-osd.sh

### END OF CUSTOM BINDS


bind=$mainMod, V, togglefloating
bind=$mainMod, J, togglesplit
bind=$mainMod, 1, workspace, 1
bind=$mainMod, 2, workspace, 2
bind=$mainMod, 3, workspace, 3
bind=$mainMod, 4, workspace, 4
bind=$mainMod, 5, workspace, 5
bind=$mainMod, 6, workspace, 6
bind=$mainMod, 7, workspace, 7
bind=$mainMod, 8, workspace, 8
bind=$mainMod, 9, workspace, 9
bind=$mainMod, 0, workspace, 10
bind=$mainMod SHIFT, 1, movetoworkspace, 1
bind=$mainMod SHIFT, 2, movetoworkspace, 2
bind=$mainMod SHIFT, 3, movetoworkspace, 3
bind=$mainMod SHIFT, 4, movetoworkspace, 4
bind=$mainMod SHIFT, 5, movetoworkspace, 5
bind=$mainMod SHIFT, 6, movetoworkspace, 6
bind=$mainMod SHIFT, 7, movetoworkspace, 7
bind=$mainMod SHIFT, 8, movetoworkspace, 8
bind=$mainMod SHIFT, 9, movetoworkspace, 9
bind=$mainMod SHIFT, 0, movetoworkspace, 10
bind=$mainMod, mouse_down, workspace, e+1
bind=$mainMod, mouse_up, workspace, e-1
binde=$mainMod, Q, killactive
bindl=, XF86AudioNext, exec, playerctl next
bindl=, XF86AudioPause, exec, playerctl play-pause
bindl=, XF86AudioPlay, exec, playerctl play-pause
bindl=, XF86AudioPrev, exec, playerctl previous
bindm=$mainMod, mouse:272, movewindow
bindm=$mainMod, mouse:273, resizewindow
env=XCURSOR_SIZE,16
env=HYPRCURSOR_SIZE,16
env=XCURSOR_THEME,Bibata-Modern-Classic
env=NIXOS_OZONE_WL,1
env=SDL_VIDEODRIVER,wayland
env=GDK_BACKEND,wayland
env=QT_QPA_PLATFORM,wayland
env = GTK_CSD=1

layerrule = blur, rofi

monitor=eDP-1, 1920x1080@60, 0x0, 1
monitor = HDMI-A-1, 1920x1080, -1920x0, 1

# Fix XWayland ghost windows
windowrule = nofocus, class:^$,title:^$,xwayland:1,floating:1,fullscreen:0,pinned:0

# Logo
windowrule = float, class:^(Logo)$
windowrule = center, class:^(Logo)$
windowrule = size 401 375, class:^(Logo)$

# FloatingTerm
windowrule = float, class:^(FloatingTerm)$
windowrule = center, class:^(FloatingTerm)$
windowrule = size 740 450, class:^(FloatingTerm)$

# ChatGPT
windowrule = float, class:^(ChatGPT)$
windowrule = center, class:^(ChatGPT)$
windowrule = size 850 560, class:^(ChatGPT)$

# FloatingTermL
windowrule = float, class:^(FloatingTermL)$
windowrule = center, class:^(FloatingTermL)$
windowrule = size 850 560, class:^(FloatingTermL)$

# FloatingTermS
windowrule = float, class:^(FloatingTermS)$
windowrule = center, class:^(FloatingTermS)$
windowrule = size 626 325, class:^(FloatingTermS)$

# Calculator
windowrule = float, class:^(Calculator)$
windowrule = center, class:^(Calculator)$
windowrule = size 420 200, class:^(Calculator)$

# Opacity
windowrule = opacity 0.75 0.75, class:^(discord)$
windowrule = opacity 0.85 0.85, class:^(kitty)$
windowrule = opacity 0.85 0.85, class:^(nvim)$
windowrule = opacity 0.85 0.85, class:^(spotify)$
windowrule = opacity 0.85 0.85, class:^(code)$
windowrule = opacity 0.85 0.85, fullscreen:1

